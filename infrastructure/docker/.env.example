# PayNext Docker Environment Variables
# Copy this file to .env and fill in the values

# ─── Required Secrets ────────────────────────────────────────────────────────
DB_PASSWORD=change_me_strong_password
JWT_SECRET=change_me_min_32_chars_random_string
REDIS_PASSWORD=change_me_redis_password
PAYMENT_GATEWAY_KEY=change_me_payment_gateway_api_key
NOTIFICATION_API_KEY=change_me_notification_api_key
GRAFANA_PASSWORD=change_me_grafana_admin_password

# ─── Application Config ───────────────────────────────────────────────────────
IMAGE_TAG=latest
SPRING_PROFILES_ACTIVE=docker
