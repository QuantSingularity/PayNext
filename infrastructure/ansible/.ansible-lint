---
profile: production

skip_list:
  - yaml[line-length]
  - name[casing]
  - no-changed-when

warn_list:
  - experimental
  - role-name

exclude_paths:
  - .cache/
  - .git/

offline: false
use_default_rules: true

kinds:
  - playbooks: "playbooks/*.yml"
  - tasks: "roles/*/tasks/*.yml"
  - handlers: "roles/*/handlers/*.yml"
  - vars: "roles/*/vars/*.yml"
  - defaults: "roles/*/defaults/*.yml"
