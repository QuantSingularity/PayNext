# PayNext Backend Environment Variables
# Copy this file to .env and fill in actual values
# NEVER commit .env to version control

# ── Spring Profile ────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev

# ── JWT ───────────────────────────────────────────────────────────────────
# Must be at least 32 characters for HS512
JWT_SECRET=change-this-to-a-secure-random-secret-at-least-32-chars

# ── Database ─────────────────────────────────────────────────────────────
DB_PASSWORD=changeme

# ── Email (SMTP) ─────────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-specific-password

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Kafka ─────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# ── Twilio (SMS OTP) ──────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ── Eureka ────────────────────────────────────────────────────────────────
EUREKA_CLIENT_SERVICEURL_DEFAULTZONE=http://eureka-server:8001/eureka/
